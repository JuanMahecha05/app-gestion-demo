generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TimeEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

model Project {
  id          String   @id @default(cuid())
  name        String
  company     String
  country     String
  currency    String
  budget      Decimal  @db.Decimal(14, 2)
  startDate   DateTime
  endDate     DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timeEntries TimeEntry[]
  expenses    Expense[]
  forecasts   Forecast[]
}

model Consultant {
  id          String      @id @default(cuid())
  fullName    String
  email       String?
  role        String
  hourlyRate  Decimal?    @db.Decimal(14, 2)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  timeEntries TimeEntry[]
  forecasts   Forecast[]
}

model TimeEntry {
  id            String          @id @default(cuid())
  projectId     String
  consultantId  String
  workDate      DateTime
  hours         Decimal         @db.Decimal(8, 2)
  note          String?
  status        TimeEntryStatus @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultant    Consultant      @relation(fields: [consultantId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([consultantId])
  @@index([status])
  @@index([workDate])
}

model Expense {
  id          String    @id @default(cuid())
  projectId   String
  expenseDate DateTime
  category    String
  amount      Decimal   @db.Decimal(14, 2)
  currency    String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expenseDate])
}

model Forecast {
  id             String    @id @default(cuid())
  projectId      String
  consultantId   String
  period         String
  hoursProjected Decimal   @db.Decimal(10, 2)
  hourlyRate     Decimal?  @db.Decimal(14, 2)
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultant     Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([consultantId])
  @@index([period])
}

model FxConfig {
  id        String   @id @default(cuid())
  baseCode  String
  quoteCode String
  rate      Decimal  @db.Decimal(18, 6)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
