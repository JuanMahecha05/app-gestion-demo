PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.up.railway.app
# Multiple origins are supported as comma-separated URLs
# CORS_ORIGIN=https://your-frontend-domain.up.railway.app,https://your-custom-domain.com
DATABASE_URL="postgresql://postgres:<password>@postgres.railway.internal:5432/railway"

# Authentication
AUTH_ENABLED=true
AZURE_AD_TENANT_ID=<entra-tenant-id>
AZURE_AD_AUDIENCE=api://<backend-app-id-uri-or-client-id>
ADMIN_EMAIL=admin@yourcompany.com
